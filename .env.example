# Copy to .env (local), .env.staging, .env.production etc. and fill in real values.
# None of these files are committed; only this example is.

# --- Supabase (app runtime) ---
# Key formats: Supabase replaced the legacy JWT-based anon/service_role keys with
# new `sb_publishable_*` / `sb_secret_*` keys (legacy deprecated end of 2026).
# The env var NAMES below are unchanged; only the values change. supabase-js
# accepts either format transparently — no code changes needed.
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=  # new format: sb_publishable_...
SUPABASE_SERVICE_ROLE=     # new format: sb_secret_...

# --- The Odds API (server only) ---
# Two keys are rotated round-robin to stretch the free monthly quota.
PUBLIC_ODDS_API_BASE=https://api.the-odds-api.com/v4
ODDS_API_KEY1=
ODDS_API_KEY2=

# --- AI Gateway (server only, ADR-0008 AI voice) ---
# Vercel AI Gateway, OpenAI-compatible endpoint. The URL is the public gateway host (the app
# appends /v1/chat/completions); the token is the per-project secret from the Vercel project env
# (dashboard → Settings → Environment Variables, or `vercel env pull`). BOTH must be set for real
# LLM recap/Wrapped prose — without them the voice layer serves deterministic fallback copy and
# `pnpm demo:snapshot` writes meta.aiProse: "fallback". Put them in .env.local to bake real demo
# prose from a plain local run (see the refresh-demo-snapshot skill).
AI_GATEWAY_URL=https://ai-gateway.vercel.sh
AI_GATEWAY_TOKEN=   # Vercel AI Gateway API key (server-only secret)

# --- Integration tests (tests/integration/_auth.ts mints user JWTs) ---
# Local Supabase JWT secret (`supabase status` shows it).
JWT_SECRET=

# --- Cron jobs (GitHub Actions → Vercel endpoints) ---
CRON_SECRET=   # shared secret; set in Vercel + GH Actions environments

# --- Health watchdog (issue #206; docs/observability/health-watchdog.md) ---
# Token guarding GET /api/health. Set in Vercel and append as ?token=... to the
# external uptime monitor's URL. Unset/blank = endpoint returns 401 (fail closed).
HEALTH_CHECK_TOKEN=

# --- Feedback → GitHub filing (issue #500, ADR-0028; server only) ---
# Fine-grained PAT scoped to Issues:write + Metadata:read on doughill1000/sunday_bets
# ONLY. The admin feedback queue (/admin/feedback) uses it to file a sanitized public
# issue from a stored feedback row. Never exposed client-side. Unset/blank/expired =
# "File to GitHub" degrades to a prefilled new-issue URL the operator opens manually
# (never a hard fail). Fine-grained PATs expire in ≤366 days — rotation is on the
# launch-readiness ops checklist.
GITHUB_FEEDBACK_TOKEN=

# --- Beta tag (issue #697, ADR-0028 follow-up; build-time only, read by vite.config.ts) ---
# Controls whether the header "Beta" tag (opens the feedback sheet) renders. Defaults to
# shown; set to "false" to flip it off in one change at the public epoch. Baked into the
# client bundle at build time via the __SHOW_BETA_TAG__ define — not read at runtime.
SHOW_BETA_TAG=

# --- Web push notifications (VAPID) ---
# Generate once with: npx web-push generate-vapid-keys
# Set all three in Vercel (Production + Preview) and the GH Actions Production env.
PUBLIC_VAPID_PUBLIC_KEY=   # client-visible application server key
VAPID_PRIVATE_KEY=         # server-only signing key
VAPID_SUBJECT=mailto:doughill1000@gmail.com  # contact URI required by web-push

# --- Tooling (not needed by the app itself) ---
# pg_dump connection string for supabase/scripts/backup-db.mjs
DATABASE_URL=
# Source-map upload for vite builds (lives in .env.sentry-build-plugin)
SENTRY_AUTH_TOKEN=

# --- DB clone (supabase/scripts/cloneDb.ts → pnpm db:reset:local / db:clone:*) ---
# Postgres connection strings used only by the prod→local/dev clone; NOT read by the app.
# SUPABASE_DB_URL_PROD is main-checkout / shell-env only — it is not committed to any
# .env* and is not copied into git worktrees, so `pnpm db:reset:local` can't prod-clone
# from a worktree (use `pnpm db:push:local` there for a data-free schema apply).
SUPABASE_DB_URL_PROD=    # clone source (prod); main-checkout / shell env only
SUPABASE_DB_URL_LOCAL=   # clone destination for --target=local (pnpm db:clone:local)
SUPABASE_DB_URL_DEV=     # clone destination for --target=dev (pnpm db:clone:dev)
