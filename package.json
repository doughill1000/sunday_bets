{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:backfill:local": "cross-env DOTENV_CONFIG_PATH=.env.local node -r dotenv/config --import tsx supabase/scripts/backfill-picks/index.ts \"C:/Users/dough/code/sunday_bets/NFL 2025.xlsx\" --season 2025 --lock-at-kickoff",
    "db:backfill:dev": "cross-env DOTENV_CONFIG_PATH=.env.staging node -r dotenv/config --import tsx supabase/scripts/backfill-picks/index.ts \"C:/Users/dough/code/sunday_bets/NFL 2025.xlsx\" --season 2025 --lock-at-kickoff",
    "db:backfill:prod": "cross-env DOTENV_CONFIG_PATH=.env.production node -r dotenv/config --import tsx supabase/scripts/backfill-picks/index.ts \"C:/Users/dough/code/sunday_bets/NFL 2025.xlsx\" --season 2025 --lock-at-kickoff",
    "db:backup:prod": "node -r dotenv/config supabase/scripts/backup-db.mjs dotenv_config_path=.env.production",
    "db:clone:dev": "cd supabase/scripts/ && tsx cloneDb.ts --target=dev --reset",
    "db:clone:local": "cd supabase/scripts/ && tsx cloneDb.ts --target=local --reset",
    "db:reset:local": "supabase db reset --local --yes && pnpm db:clone:local",
    "db:migration": "tsx supabase/scripts/generate-migration.ts",
    "db:migration:bootstrap": "tsx supabase/scripts/generate-migration.ts --bootstrap",
    "db:push:dev": "supabase link --project-ref fhjmfpuanzmowmsfmuhi && supabase db push --yes",
    "db:push:local": "supabase db push --local --yes && pnpm db:types",
    "db:types": "supabase gen types typescript --local > src/lib/types/supabase.ts",
    "dev": "vite dev --host --port 5173",
    "lint": "prettier --check . && eslint .",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "serve": "vite build && vite preview",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest --run",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:coverage": "pnpm test:unit --coverage && pnpm test:integration --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.1",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.515.0",
    "@playwright/test": "^1.57.0",
    "@sveltejs/adapter-vercel": "^5.10.3",
    "@sveltejs/kit": "^2.49.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.0",
    "execa": "^9.6.1",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.57.0",
    "postgres": "^3.4.7",
    "prettier": "^3.7.3",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn-svelte": "^1.3.0",
    "supabase": "^2.64.2",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4",
    "workbox-window": "^7.4.1",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.27.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.86.0",
    "date-fns": "^4.1.0"
  }
}
