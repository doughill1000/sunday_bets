{
  "name": "web",
  "private": true,
  "version": "3.11.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:backfill:local": "cross-env DOTENV_CONFIG_PATH=.env.local node -r dotenv/config --import tsx supabase/scripts/backfill-picks/index.ts \"C:/Users/dough/code/sunday_bets/NFL 2025.xlsx\" --season 2025 --lock-at-kickoff",
    "db:backfill:dev": "cross-env DOTENV_CONFIG_PATH=.env.staging node -r dotenv/config --import tsx supabase/scripts/backfill-picks/index.ts \"C:/Users/dough/code/sunday_bets/NFL 2025.xlsx\" --season 2025 --lock-at-kickoff",
    "db:backfill:prod": "cross-env DOTENV_CONFIG_PATH=.env.production node -r dotenv/config --import tsx supabase/scripts/backfill-picks/index.ts \"C:/Users/dough/code/sunday_bets/NFL 2025.xlsx\" --season 2025 --lock-at-kickoff",
    "db:import-historical:generate": "tsx supabase/scripts/import-historical/generate.ts",
    "db:backfill-game-times:generate": "tsx supabase/scripts/backfill-game-times/generate.ts",
    "db:backup:prod": "node -r dotenv/config supabase/scripts/backup-db.mjs dotenv_config_path=.env.production",
    "db:refresh-matviews:prod": "node -r dotenv/config supabase/scripts/refresh-matviews.mjs dotenv_config_path=.env.production",
    "refresh-wrapped:prod": "cross-env DOTENV_CONFIG_PATH=.env.production node -r dotenv/config --import tsx supabase/scripts/refresh-wrapped/index.ts",
    "db:clone:dev": "cd supabase/scripts/ && tsx cloneDb.ts --target=dev --reset",
    "db:clone:local": "cd supabase/scripts/ && tsx cloneDb.ts --target=local --reset",
    "db:reset:local": "supabase db reset --local --yes && pnpm db:clone:local",
    "db:seed:demo": "cross-env DOTENV_CONFIG_PATH=.env.local node -r dotenv/config --import tsx supabase/scripts/seed-demo/index.ts",
    "demo:snapshot": "cross-env DOTENV_CONFIG_PATH=.env.local tsx supabase/scripts/demo-snapshot/index.ts",
    "db:reset:demo": "supabase db reset --local --yes && pnpm db:seed:demo",
    "db:migration": "tsx supabase/scripts/generate-migration.ts",
    "db:migration:bootstrap": "tsx supabase/scripts/generate-migration.ts --bootstrap",
    "db:migration:check": "tsx supabase/scripts/generate-migration.ts --check",
    "db:migration:verify": "tsx supabase/scripts/verify-src-reproduces-migrations.ts",
    "db:push:dev": "supabase link --project-ref eoncckeqqogezoftooix && supabase db push --yes",
    "db:push:local": "supabase db push --local --yes && pnpm db:types",
    "db:types": "supabase gen types typescript --local > src/lib/types/supabase.ts",
    "governance:check": "tsx scripts/check-governance-freshness.ts",
    "users:provision:local": "tsx supabase/scripts/provision-users.ts --env=.env.local --file=supabase/scripts/users.json",
    "users:provision:dev": "tsx supabase/scripts/provision-users.ts --env=.env.staging --file=supabase/scripts/users.json",
    "users:provision:prod": "tsx supabase/scripts/provision-users.ts --env=.env.production --file=supabase/scripts/users.json",
    "ratings:rebuild": "tsx scripts/rebuildRatings.ts",
    "dev": "vite dev --host",
    "lint": "prettier --check . && eslint . && tsx scripts/check-brand-colors.ts",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && git config core.hooksPath .githooks || true",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "serve": "vite build && vite preview",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest --run",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:coverage": "pnpm test:unit --coverage && pnpm test:integration --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.25.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/svelte-query-devtools": "^6.1.38",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/svelte": "^5.4.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/web-push": "^3.6.4",
    "@vite-pwa/sveltekit": "^1.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.22.0",
    "execa": "^10.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.61.1",
    "postgres": "^3.4.9",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "shadcn-svelte": "^1.4.2",
    "supabase": "^2.109.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.1",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.67.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "@tanstack/query-async-storage-persister": "^5.101.4",
    "@tanstack/svelte-query": "^6.1.38",
    "@tanstack/svelte-query-persist-client": "^6.1.38",
    "ai": "^7.0.35",
    "date-fns": "^4.4.0",
    "idb-keyval": "^6.3.0",
    "layerchart": "2.0.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  }
}
