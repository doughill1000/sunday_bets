# Supabase project the mobile app talks to. Values are bundled into the client at
# build time (EXPO_PUBLIC_* is public by design — same trust level as the web
# app's PUBLIC_* vars).
#
# Use the staging or production values from the web app's .env.staging /
# .env.production. The local Supabase stack (http://127.0.0.1:54321) is NOT
# reachable from a phone — if you need it, substitute your machine's LAN IP.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
