{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "db:push:dev": "cross-env SUPABASE_PROJECT_REF=fhjmfpuanzmowmsfmuhi supabase db push",
    "db:push:prod": "cross-env SUPABASE_PROJECT_REF=anzcshrpfpxajcgrwczv supabase db push",
    "db:gen:migration": "tsx supabase/scripts/generate-migration.ts",
    "db:gen:migration:bootstrap": "tsx supabase/scripts/generate-migration.ts --bootstrap",
    "dev": "vite dev --host --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite build && vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "supa:gen": "supabase gen types typescript --project-id fhjmfpuanzmowmsfmuhi > src/lib/server/db/types.ts"
  },
